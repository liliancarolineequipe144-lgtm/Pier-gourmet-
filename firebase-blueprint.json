{
  "entities": {
    "MenuItem": {
      "title": "MenuItem",
      "description": "A product in the digital menu",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "description", "price", "category"]
    }
  },
  "firestore": {
    "/menu": {
      "schema": "MenuItem",
      "description": "Collection of menu items"
    }
  }
}
